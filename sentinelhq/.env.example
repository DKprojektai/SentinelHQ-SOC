# ═══════════════════════════════════════════════════════
#  SentinelHQ — Environment Configuration
# ═══════════════════════════════════════════════════════

# Organization
ORG_NAME=Acme Corp

# ── Database ─────────────────────────────────────────
DB_NAME=sentinelhq
DB_USER=shq
DB_PASS=strong-random-password-here

# ── OpenSearch / Wazuh Indexer ────────────────────────
OPENSEARCH_URL=https://wazuh.indexer:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=SecretPassword
OPENSEARCH_INDEX=wazuh-alerts-*
WAZUH_VERIFY_SSL=false

# ── Wazuh Manager API (for Active Response) ───────────
WAZUH_API_URL=https://wazuh.manager:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASS=MyS3cr37P450r.*-

# Wazuh Docker network name
WAZUH_NETWORK=single-node_default

# ── Collector ─────────────────────────────────────────
COLLECT_INTERVAL_SECONDS=30

# ── Analyzer ─────────────────────────────────────────
ANALYZE_INTERVAL_SECONDS=600
NOISE_THRESHOLD_HOURLY=20
NOISE_WINDOW_HOURS=72
MIN_OCCURRENCES=10
RULE_ID_START=122000
RULE_ID_MAX=122999

# ── LLM konfigūracija (OpenAI-compatible API) ────────────────────────────────
# OpenRouter:
#   LLM_API_URL=https://openrouter.ai/api/v1
#   LLM_API_KEY=sk-or-...
#   LLM_MODEL=google/gemini-2.5-flash
#
# LM Studio (lokalus):
#   LLM_API_URL=http://host.docker.internal:1234/v1
#   LLM_API_KEY=lm-studio
#   LLM_MODEL=llama-3.2-3b-instruct
#
# Ollama (lokalus):
#   LLM_API_URL=http://host.docker.internal:11434/v1
#   LLM_API_KEY=ollama
#   LLM_MODEL=llama3.2
#
# Bet koks kitas OpenAI-compatible:
#   LLM_API_URL=https://api.together.xyz/v1
#   LLM_API_KEY=...
#   LLM_MODEL=meta-llama/Llama-3-70b-chat-hf

LLM_API_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-your-key-here
LLM_MODEL=google/gemini-2.5-flash
LLM_POLL_INTERVAL=30

# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHI...
TELEGRAM_CHAT_ID=-100123456789

# ── Dashboard (admin UI) ──────────────────────────────
DASHBOARD_PORT=8082
DASHBOARD_USER=admin
DASHBOARD_PASS=strong-admin-password
# Generuok: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-64-random-chars

# ── Client Portal ─────────────────────────────────────
PORTAL_PORT=8083
# Klientų vartotojai kuriami per dashboard

# ── Reporter / Email ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
REPORT_EMAIL_TO=client@company.com
REPORT_DAY=monday
REPORT_HOUR=8

# ── Correlator ────────────────────────────────────────
CORRELATE_INTERVAL=120
CORRELATE_WINDOW=10

